{
  "dev": {
    "namespace": "websete",
    "network": "speculum-dev",
    "env": [
      { "name": "TRAEFIK_MOTOR_DOMAIN", "value": "speculum.localhost" },
      { "name": "TRAEFIK_API_DOMAIN", "value": "api.speculum.localhost" },
      { "name": "ACME_EMAIL", "value": "" }
    ],
    "containers": [
      {
        "id": "traefik",
        "imageRef": "traefik:v3.6.1",
        "command": [
          "--api.dashboard=false",
          "--providers.docker=true",
          "--providers.docker.exposedbydefault=false",
          "--providers.docker.network=speculum-dev",
          "--entrypoints.web.address=:80"
        ],
        "ports": [
          { "host": 8080, "container": 80 }
        ],
        "volumes": [
          { "host": "/var/run/docker.sock", "container": "/var/run/docker.sock:ro" }
        ]
      },
      {
        "id": "sidecar",
        "image": "speculum-sidecar",
        "context": "sidecar",
        "dockerfile": "Dockerfile",
        "capAdd": ["SYS_ADMIN"],
        "shmSize": "2gb",
        "env": [
          { "name": "NODE_ENV", "value": "production" },
          { "name": "SIDECAR_PORT", "value": "3000" }
        ],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:3000/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        }
      },
      {
        "id": "api",
        "image": "speculum-api",
        "context": "Speculum.Api",
        "dockerfile": "Dockerfile",
        "dependsOn": [{ "id": "sidecar", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:8080/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        },
        "env": [
          { "name": "ASPNETCORE_ENVIRONMENT", "value": "Development" },
          { "name": "HttpAddress", "value": "0.0.0.0:8080" },
          { "name": "Database__Path", "value": "/data/speculum.db" },
          { "name": "Sidecar__BaseUrl", "value": "ws://sidecar:3000" },
          { "name": "Cors__AllowedOrigins", "value": "http://speculum.localhost:8080;http://localhost:5173" },
          { "name": "Motor__PublicDomain", "value": "${TRAEFIK_MOTOR_DOMAIN}" },
          { "name": "ADMIN_BOOTSTRAP_KEY", "value": "password" }
        ],
        "volumes": [{ "name": "speculum-data", "container": "/data" }],
        "labels": [
          "traefik.enable=true",
          "traefik.http.routers.speculum-api.rule=Host(`${TRAEFIK_API_DOMAIN}`) || Host(`${TRAEFIK_API_DOMAIN}:8080`)",
          "traefik.http.routers.speculum-api.entrypoints=web",
          "traefik.http.services.speculum-api.loadbalancer.server.port=8080"
        ]
      },
      {
        "id": "web",
        "image": "speculum-web",
        "context": "web",
        "dockerfile": "Dockerfile",
        "buildArgs": [
          { "name": "VITE_API_URL", "value": "http://api.speculum.localhost:8080" }
        ],
        "dependsOn": [{ "id": "api", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "wget", "-qO-", "http://localhost/"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "10s",
          "retries": 3
        },
        "labels": [
          "traefik.enable=true",
          "traefik.http.routers.speculum-web.rule=Host(`${TRAEFIK_MOTOR_DOMAIN}`) || Host(`${TRAEFIK_MOTOR_DOMAIN}:8080`)",
          "traefik.http.routers.speculum-web.entrypoints=web",
          "traefik.http.services.speculum-web.loadbalancer.server.port=80"
        ]
      }
    ],
    "volumes": [{ "name": "speculum-data" }]
  },
  "prod": {
    "namespace": "websete",
    "network": "speculum",
    "env": [
      { "name": "TRAEFIK_MOTOR_DOMAIN", "value": "seudominio.com" },
      { "name": "TRAEFIK_API_DOMAIN", "value": "api.speculum.seudominio.com" },
      { "name": "ACME_EMAIL", "value": "admin@websete.org" }
    ],
    "containers": [
      {
        "id": "traefik",
        "imageRef": "traefik:v3.6.1",
        "entrypoint": ["/bin/sh", "-ec"],
        "command": [
          "set -a; [ -f /data/traefik/cloudflare.env ] && . /data/traefik/cloudflare.env; set +a; exec /entrypoint.sh traefik --api.dashboard=false --providers.docker=true --providers.docker.exposedbydefault=false --entrypoints.web.address=:80 --entrypoints.websecure.address=:443 --entrypoints.websecure.http.tls=true --entrypoints.web.http.redirections.entrypoint.to=websecure --entrypoints.web.http.redirections.entrypoint.scheme=https --certificatesresolvers.le.acme.httpchallenge=true --certificatesresolvers.le.acme.httpchallenge.entrypoint=web --certificatesresolvers.le.acme.email=${ACME_EMAIL} --certificatesresolvers.le.acme.storage=/letsencrypt/acme.json --certificatesresolvers.le-dns.acme.dnschallenge=true --certificatesresolvers.le-dns.acme.dnschallenge.provider=cloudflare --certificatesresolvers.le-dns.acme.dnschallenge.resolvers=1.1.1.1:53,8.8.8.8:53 --certificatesresolvers.le-dns.acme.email=${ACME_EMAIL} --certificatesresolvers.le-dns.acme.storage=/letsencrypt/acme-dns.json --providers.file.directory=/data/traefik/dynamic --providers.file.watch=true"
        ],
        "ports": [
          { "host": 80, "container": 80 },
          { "host": 443, "container": 443 }
        ],
        "volumes": [
          { "host": "/var/run/docker.sock", "container": "/var/run/docker.sock:ro" },
          { "name": "traefik-letsencrypt", "container": "/letsencrypt" },
          { "name": "speculum-data", "container": "/data" }
        ],
        "env": [
          { "name": "ACME_EMAIL", "value": "${ACME_EMAIL}" }
        ]
      },
      {
        "id": "sidecar",
        "image": "speculum-sidecar",
        "context": "sidecar",
        "dockerfile": "Dockerfile",
        "capAdd": ["SYS_ADMIN"],
        "shmSize": "2gb",
        "env": [
          { "name": "NODE_ENV", "value": "production" },
          { "name": "SIDECAR_PORT", "value": "3000" }
        ],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:3000/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        }
      },
      {
        "id": "api",
        "image": "speculum-api",
        "context": "Speculum.Api",
        "dockerfile": "Dockerfile",
        "dependsOn": [{ "id": "sidecar", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:8080/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        },
        "env": [
          { "name": "ASPNETCORE_ENVIRONMENT", "value": "Production" },
          { "name": "HttpAddress", "value": "0.0.0.0:8080" },
          { "name": "Database__Path", "value": "/data/speculum.db" },
          { "name": "Sidecar__BaseUrl", "value": "ws://sidecar:3000" },
          { "name": "Cors__AllowedOrigins", "value": "https://${TRAEFIK_MOTOR_DOMAIN}" },
          { "name": "Motor__PublicDomain", "value": "${TRAEFIK_MOTOR_DOMAIN}" },
          { "name": "Traefik__DynamicDir", "value": "/data/traefik/dynamic" }
        ],
        "volumes": [{ "name": "speculum-data", "container": "/data" }],
        "labels": [
          "traefik.enable=true",
          "traefik.http.routers.speculum-api.rule=Host(`${TRAEFIK_API_DOMAIN}`)",
          "traefik.http.routers.speculum-api.entrypoints=websecure",
          "traefik.http.routers.speculum-api.tls.certresolver=le",
          "traefik.http.services.speculum-api.loadbalancer.server.port=8080"
        ]
      },
      {
        "id": "web",
        "image": "speculum-web",
        "context": "web",
        "dockerfile": "Dockerfile",
        "buildArgs": [
          { "name": "VITE_API_URL", "value": "https://${TRAEFIK_API_DOMAIN}" }
        ],
        "dependsOn": [{ "id": "api", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "wget", "-qO-", "http://localhost/"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "10s",
          "retries": 3
        },
        "labels": [
          "traefik.enable=true",
          "traefik.http.routers.speculum-web.rule=Host(`${TRAEFIK_MOTOR_DOMAIN}`)",
          "traefik.http.routers.speculum-web.entrypoints=websecure",
          "traefik.http.routers.speculum-web.tls.certresolver=le",
          "traefik.http.services.speculum-web.loadbalancer.server.port=80"
        ]
      }
    ],
    "volumes": [
      { "name": "speculum-data" },
      { "name": "traefik-letsencrypt" }
    ]
  }
}

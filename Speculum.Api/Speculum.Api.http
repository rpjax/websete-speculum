@host = http://localhost:8080
@adminKey = {{$dotenv ADMIN_BOOTSTRAP_KEY}}

### Health (public)
GET {{host}}/health

### Setup status (public)
GET {{host}}/api/admin/config/status

### Client config (public)
GET {{host}}/api/public/client-config

### Forwarding (requires auth)
PUT {{host}}/api/admin/config/Forwarding
Authorization: Bearer {{adminKey}}
Content-Type: application/json

{
  "host": "www.exemplo.com",
  "domains": ["exemplo.com", "*.exemplo.com"]
}

### MaxSessions (requires auth)
PUT {{host}}/api/admin/config/MaxSessions
Authorization: Bearer {{adminKey}}
Content-Type: application/json

10

### Session policy (requires auth)
PUT {{host}}/api/admin/config/SessionPolicy
Authorization: Bearer {{adminKey}}
Content-Type: application/json

{
  "ttlDays": 30
}

### Subdomain mirroring — disable (requires auth)
PUT {{host}}/api/admin/config/SubdomainMirroring
Authorization: Bearer {{adminKey}}
Content-Type: application/json

{
  "enabled": false
}

### List browser sessions (requires auth)
GET {{host}}/api/admin/sessions
Authorization: Bearer {{adminKey}}

### Change admin key (requires current key)
PUT {{host}}/api/admin/config/Admin
Authorization: Bearer {{adminKey}}
Content-Type: application/json

{
  "apiKey": "your-new-secret"
}

{
  "dev": {
    "namespace": "websete",
    "network": "speculum-dev",
    "containers": [
      {
        "id": "traefik",
        "imageRef": "traefik:v3.6.1",
        "dependsOn": [{ "id": "api", "condition": "service_healthy" }],
        "command": [
          "--api.dashboard=false",
          "--providers.docker=true",
          "--providers.docker.exposedbydefault=false",
          "--providers.docker.network=speculum-dev",
          "--entrypoints.web.address=:80",
          "--providers.file.directory=/data/traefik/dynamic",
          "--providers.file.watch=true"
        ],
        "ports": [
          { "host": 8080, "container": 80 }
        ],
        "volumes": [
          { "host": "/var/run/docker.sock", "container": "/var/run/docker.sock:ro" },
          { "name": "speculum-data", "container": "/data" }
        ]
      },
      {
        "id": "sidecar",
        "image": "speculum-sidecar",
        "context": "sidecar",
        "dockerfile": "Dockerfile",
        "capAdd": ["SYS_ADMIN"],
        "shmSize": "2gb",
        "env": [
          { "name": "NODE_ENV", "value": "production" },
          { "name": "SIDECAR_PORT", "value": "3000" }
        ],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:3000/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        }
      },
      {
        "id": "api",
        "image": "speculum-api",
        "context": "Speculum.Api",
        "dockerfile": "Dockerfile",
        "dependsOn": [{ "id": "sidecar", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:8080/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        },
        "env": [
          { "name": "ASPNETCORE_ENVIRONMENT", "value": "Development" },
          { "name": "HttpAddress", "value": "0.0.0.0:8080" },
          { "name": "Database__Path", "value": "/data/speculum.db" },
          { "name": "Sidecar__BaseUrl", "value": "ws://sidecar:3000" },
          { "name": "Cors__AllowedOrigins", "value": "http://localhost:5173;http://127.0.0.1:5173;http://speculum.localhost:8080" },
          { "name": "Traefik__Root", "value": "/data/traefik" },
          { "name": "Traefik__DynamicDir", "value": "/data/traefik/dynamic" },
          { "name": "Traefik__DockerSocket", "value": "/var/run/docker.sock" },
          { "name": "ADMIN_BOOTSTRAP_KEY", "value": "password" },
          { "name": "SPECULUM_DIAGNOSTICS_PROFILE", "value": "Assertive" }
        ],
        "volumes": [
          { "name": "speculum-data", "container": "/data" },
          { "host": "/var/run/docker.sock", "container": "/var/run/docker.sock:ro" }
        ],
        "labels": [
          "traefik.enable=true",
          "traefik.http.services.speculum-api.loadbalancer.server.port=8080"
        ]
      },
      {
        "id": "web",
        "image": "speculum-web",
        "context": "web",
        "dockerfile": "Dockerfile",
        "dependsOn": [{ "id": "api", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "wget", "-qO-", "http://localhost/"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "10s",
          "retries": 3
        },
        "labels": [
          "traefik.enable=true",
          "traefik.http.services.speculum-web.loadbalancer.server.port=80"
        ]
      }
    ],
    "volumes": [{ "name": "speculum-data" }]
  },
  "prod": {
    "namespace": "websete",
    "network": "speculum",
    "containers": [
      {
        "id": "traefik",
        "imageRef": "traefik:v3.6.1",
        "dependsOn": [{ "id": "api", "condition": "service_healthy" }],
        "entrypoint": ["/bin/sh", "-ec"],
        "command": [
          "set -a; for f in /data/traefik/cloudflare-*.env; do [ -f \"$$f\" ] && . \"$$f\"; done; set +a; exec /entrypoint.sh traefik --api.dashboard=false --providers.docker=true --providers.docker.exposedbydefault=false --providers.docker.network=speculum --entrypoints.web.address=:80 --entrypoints.websecure.address=:443 --entrypoints.websecure.http.tls=true --providers.file.directory=/data/traefik/dynamic --providers.file.watch=true"
        ],
        "ports": [
          { "host": 80, "container": 80 },
          { "host": 443, "container": 443 }
        ],
        "volumes": [
          { "host": "/var/run/docker.sock", "container": "/var/run/docker.sock:ro" },
          { "name": "traefik-letsencrypt", "container": "/letsencrypt" },
          { "name": "speculum-data", "container": "/data" }
        ]
      },
      {
        "id": "sidecar",
        "image": "speculum-sidecar",
        "context": "sidecar",
        "dockerfile": "Dockerfile",
        "capAdd": ["SYS_ADMIN"],
        "shmSize": "2gb",
        "env": [
          { "name": "NODE_ENV", "value": "production" },
          { "name": "SIDECAR_PORT", "value": "3000" }
        ],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:3000/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        }
      },
      {
        "id": "api",
        "image": "speculum-api",
        "context": "Speculum.Api",
        "dockerfile": "Dockerfile",
        "dependsOn": [{ "id": "sidecar", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "curl", "-sf", "http://localhost:8080/health"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "20s",
          "retries": 3
        },
        "env": [
          { "name": "ASPNETCORE_ENVIRONMENT", "value": "Production" },
          { "name": "HttpAddress", "value": "0.0.0.0:8080" },
          { "name": "Database__Path", "value": "/data/speculum.db" },
          { "name": "Sidecar__BaseUrl", "value": "ws://sidecar:3000" },
          { "name": "Traefik__Root", "value": "/data/traefik" },
          { "name": "Traefik__DynamicDir", "value": "/data/traefik/dynamic" },
          { "name": "Traefik__DockerSocket", "value": "/var/run/docker.sock" }
        ],
        "volumes": [
          { "name": "speculum-data", "container": "/data" },
          { "host": "/var/run/docker.sock", "container": "/var/run/docker.sock:ro" }
        ],
        "labels": [
          "traefik.enable=true",
          "traefik.http.services.speculum-api.loadbalancer.server.port=8080"
        ]
      },
      {
        "id": "web",
        "image": "speculum-web",
        "context": "web",
        "dockerfile": "Dockerfile",
        "dependsOn": [{ "id": "api", "condition": "service_healthy" }],
        "healthcheck": {
          "test": ["CMD", "wget", "-qO-", "http://localhost/"],
          "interval": "15s",
          "timeout": "5s",
          "startPeriod": "10s",
          "retries": 3
        },
        "labels": [
          "traefik.enable=true",
          "traefik.http.services.speculum-web.loadbalancer.server.port=80"
        ]
      }
    ],
    "volumes": [
      { "name": "speculum-data" },
      { "name": "traefik-letsencrypt" }
    ]
  }
}
